{
  "name": "ai-assistant-status-monitor",
  "version": "1.0.0",
  "description": "AI助手状态监控面板 - 支持 Kimi Code CLI 和 Claude Code",
  "main": "src/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vue-tsc --noEmit && vite build",
    "build": "npm run build:renderer && electron-builder",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "ai",
    "status",
    "monitor",
    "kimi",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^9.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "vue": "^3.5.35",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.example.ai-status-monitor",
    "productName": "AI状态监控",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
