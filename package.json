{
  "name": "ai-assistant-status-monitor",
  "version": "1.0.0",
  "description": "AI助手状态监控面板 - 支持 Kimi Code CLI 和 Claude Code",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/vue/dist/vue.global.js', 'src/renderer/vendor/vue.global.js')\"",
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "keywords": [
    "ai",
    "status",
    "monitor",
    "kimi",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "vue": "^3.5.35",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.example.ai-status-monitor",
    "productName": "AI状态监控",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
